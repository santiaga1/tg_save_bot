# Токен бота из BotFather.
BOT_TOKEN=123456789:PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE

# Максимальный размер видео в мегабайтах, которое бот будет отправлять в чат.
# У Telegram Bot API есть лимиты на размер файлов, поэтому лучше держать запас.
MAX_VIDEO_MB=48

# Необязательно: путь к cookies-файлу для yt-dlp.
# Часто нужен для Instagram, иногда помогает с TikTok и YouTube Shorts.
# Как получить cookies.txt: расширением браузера "Get cookies.txt" или через yt-dlp docs.
COOKIES_FILE=

# URL PO Token Provider для YouTube. В Docker Compose он задается автоматически.
# Для запуска без Docker можно поднять bgutil provider отдельно и указать его URL.
YTDLP_POT_PROVIDER_URL=
